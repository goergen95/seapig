# Dockerfile
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PIP_NO_CACHE_DIR=1
WORKDIR /workspace

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
     build-essential git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --home-dir /workspace/vscode vscode \
  && chown -R vscode:vscode /workspace/vscode

RUN python -m pip install --upgrade pip setuptools wheel build

COPY . /workspace/vscode
WORKDIR /workspace/vscode

RUN pip install --no-cache-dir -r requirements/required.txt 
RUN pip install --no-cache-dir -r requirements/suggested.txt
RUN pip install --no-cache-dir -r requirements/dev.txt
RUN pip install --no-cache-dir -r requirements/docs.txt
RUN pip install .
RUN quarto add machow/quartodoc --no-prompt 

USER vscode
ENV HOME=/workspace/vscode
CMD ["bash"]