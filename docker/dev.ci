# Dockerfile
FROM python:3.12-slim
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /workspace

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
     build-essential git wget ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --home-dir /workspace/seapig seapig \
  && chown -R seapig:seapig /workspace/seapig

COPY . /workspace/seapig
WORKDIR /workspace/seapig
ENV HOME=/workspace/seapig

RUN uv venv && . ./.venv/bin/activate
RUN uv pip install .[all]
RUN quarto add machow/quartodoc --no-prompt

RUN uv cache clean

USER seapig
CMD ["bash"]
